# SWE Architect MCP environment template
# Copy this file to .env, uncomment the values you need, and add your real keys.
# Do not commit .env or real API keys.

# Recommended: one generic key and model.
# The provider is inferred from the model name or API key format.
# SE_MCP_API_KEY=your-api-key-here
# SE_MCP_MODEL=gemini-2.5-flash

# Optional: force a provider instead of auto-detecting it.
# Options: anthropic, openai, google
# SE_MCP_PROVIDER=google

# Alternative: use provider-specific keys.
# Only one provider key is required.
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Optional: Mermaid diagram image rendering.
# mermaid_ink = render SVG files through mermaid.ink, requires internet
# none = save only .mmd Mermaid source files
# SE_MCP_DIAGRAM_RENDERER=mermaid_ink
