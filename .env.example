# ============================================================================
# SWE Architect MCP Server - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Only ONE provider is required. The server auto-detects which key is available.
# ============================================================================

# --- Provider Selection (optional) ---
# Override auto-detection. Options: anthropic, openai, google
# SE_MCP_PROVIDER=anthropic

# --- Model Override (optional) ---
# Override the default model for your chosen provider.
# Defaults: anthropic=claude-sonnet-4-20250514, openai=gpt-4o, google=gemini-2.5-flash
# SE_MCP_MODEL=claude-sonnet-4-20250514

# --- Anthropic ---
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- OpenAI ---
# OPENAI_API_KEY=your-openai-api-key-here

# --- Google Gemini ---
# GOOGLE_API_KEY=your-google-api-key-here

# --- Diagram Rendering ---
# How to render Mermaid diagrams to images. Options:
#   mermaid_ink  (default) — uses free mermaid.ink API, requires internet
#   none                   — skip rendering, only save .mmd text files
# SE_MCP_DIAGRAM_RENDERER=mermaid_ink
